{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pagenoise",
  "compatibility_date": "2026-05-14",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "pagenoise.davidmendoza.ch", "custom_domain": true }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
